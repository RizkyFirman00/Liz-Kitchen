<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_order_panel"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="58dp"
        android:layout_height="58dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_imageCake"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/LizKitchenRoundedImage"
            tools:src="@tools:sample/avatars" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_cakeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_semibold"
            android:maxLines="1"
            android:textColor="#3A2A20"
            android:textSize="13sp"
            tools:text="Kue Nastar - Original" />

        <TextView
            android:id="@+id/tv_itemPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="#765945"
            android:textSize="11sp"
            tools:text="Rp 55.000 / pcs" />

        <TextView
            android:id="@+id/tv_subtotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/brown_old"
            android:textSize="12sp"
            tools:text="Subtotal Rp 110.000" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_jumlahPesanan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_home_badge"
        android:fontFamily="@font/poppins_semibold"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:textColor="@color/brown_old"
        android:textSize="12sp"
        tools:text="2 pcs" />
</LinearLayout>
