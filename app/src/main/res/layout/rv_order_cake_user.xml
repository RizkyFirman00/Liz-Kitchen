<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_order_list_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_imageCake"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_order_panel"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/LizKitchenRoundedImage"
        tools:src="@drawable/null_image" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_cakeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_semibold"
            android:maxLines="2"
            android:textColor="#3A2A20"
            android:textSize="13sp"
            tools:text="Kue Nastar Premium" />

        <TextView
            android:id="@+id/tv_itemPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="#765945"
            android:textSize="12sp"
            tools:text="Rp 55.000 / pcs" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_jumlahPesanan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_order_total"
        android:fontFamily="@font/poppins_semibold"
        android:includeFontPadding="false"
        android:minWidth="48dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="7dp"
        android:textAlignment="center"
        android:textColor="@color/brown_old"
        android:textSize="12sp"
        tools:text="x2" />
</LinearLayout>
