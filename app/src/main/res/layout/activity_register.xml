<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.register.RegisterActivity">

    <ImageView
        android:id="@+id/iv_top_wave"
        android:layout_width="0dp"
        android:layout_height="320dp"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/vector_atas1" />

    <ImageView
        android:id="@+id/iv_bottom_wave"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/vector_bawah_login" />

    <ImageView
        android:id="@+id/iv_hero"
        android:layout_width="0dp"
        android:layout_height="198dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="42dp"
        android:layout_marginEnd="28dp"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/vector_login_register" />

    <ImageView
        android:id="@+id/iv_bottom_logo"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginBottom="42dp"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/logo" />

    <ScrollView
        android:id="@+id/register_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="30dp"
            android:paddingTop="248dp"
            android:paddingEnd="30dp"
            android:paddingBottom="36dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_register"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="8dp"
                app:cardElevation="6dp"
                app:cardUseCompatPadding="true"
                app:strokeColor="#EED8C8"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingTop="24dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="22dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:includeFontPadding="false"
                        android:text="Buat Akun"
                        android:textAlignment="center"
                        android:textColor="#3A2A20"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/poppins_regular"
                        android:lineSpacingExtra="2dp"
                        android:text="Daftar untuk pesan kue dan pantau status pesananmu."
                        android:textAlignment="center"
                        android:textColor="#765945"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="Email"
                        android:textColor="#3A2A20"
                        android:textSize="13sp" />

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="2dp"
                        android:background="@drawable/bg_auth_input"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Masukkan email"
                        android:importantForAutofill="yes"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="14dp"
                        android:singleLine="true"
                        android:textColor="#3A2A20"
                        android:textColorHint="#A68B78"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="No. Telepon"
                        android:textColor="#3A2A20"
                        android:textSize="13sp" />

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/et_notelp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="2dp"
                        android:background="@drawable/bg_auth_input"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Masukkan nomor telepon"
                        android:importantForAutofill="yes"
                        android:inputType="phone"
                        android:paddingHorizontal="14dp"
                        android:singleLine="true"
                        android:textColor="#3A2A20"
                        android:textColorHint="#A68B78"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="Username"
                        android:textColor="#3A2A20"
                        android:textSize="13sp" />

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/et_username"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="2dp"
                        android:background="@drawable/bg_auth_input"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Buat username"
                        android:importantForAutofill="yes"
                        android:inputType="text"
                        android:paddingHorizontal="14dp"
                        android:singleLine="true"
                        android:textColor="#3A2A20"
                        android:textColorHint="#A68B78"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="Password"
                        android:textColor="#3A2A20"
                        android:textSize="13sp" />

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="2dp"
                        android:background="@drawable/bg_auth_input"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Buat password"
                        android:importantForAutofill="yes"
                        android:inputType="textPassword"
                        android:paddingHorizontal="14dp"
                        android:singleLine="true"
                        android:textColor="#3A2A20"
                        android:textColorHint="#A68B78"
                        android:textSize="14sp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_register"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_auth_primary_button"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Daftar"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/btn_tologin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/poppins_semibold"
                        android:gravity="center"
                        android:minHeight="32dp"
                        android:text="Sudah punya akun? Masuk"
                        android:textAlignment="center"
                        android:textColor="@color/brown_old"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar2"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="12dp"
        android:indeterminateTint="@color/brown_young"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
